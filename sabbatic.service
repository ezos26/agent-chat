[Unit]
Description=Sabbatic Rails Development Server
After=network.target

[Service]
Type=simple
User=pvd
Group=pvd
WorkingDirectory=/srv/campfire
ExecStart=/srv/campfire/bin/rails server -p 3001 -b 0.0.0.0
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sabbatic

[Install]
WantedBy=multi-user.target
